{
  "name": "project-cypress-e2e",
  "version": "1.0.0",
  "description": "Data-driven Cypress automation framework for a demo commerce workflow.",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run start:services",
    "start:web": "http-server test-app -a 127.0.0.1 -p 4174 -c-1",
    "start:api": "API_PORT=5174 node test-api/server.mjs",
    "start:services": "node scripts/start-services.mjs",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:api": "cypress run --spec 'cypress/e2e/api/**/*.cy.ts'",
    "test": "start-server-and-test start http://127.0.0.1:5174/api/health cy:run",
    "test:api": "start-server-and-test start http://127.0.0.1:5174/api/health cy:run:api",
    "test:chrome": "cypress run --browser chrome",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "lint:types": "tsc --noEmit"
  },
  "devDependencies": {
    "allure-commandline": "^2.38.1",
    "allure-cypress": "^3.7.1",
    "cypress": "^14.4.1",
    "http-server": "^14.1.1",
    "start-server-and-test": "^2.0.10",
    "typescript": "^5.8.3"
  }
}
